;; This project uses {{{ / }}} fold markers throughout source and documentation.
;; Install the 'folding' package for automatic fold-marker support:
;;   M-x package-install RET folding RET
;; Then reopen the project directory.
((nil . ((eval . (when (fboundp 'folding-mode)
                   (folding-mode 1))))))
